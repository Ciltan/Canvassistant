{
  "manifest_version": 3,
  "name": "Canvas Study AI",
  "description": "AI-powered study assistant for NUS Canvas courses",
  "version": "1.0.0",
  "permissions": [],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Canvas Study AI",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
